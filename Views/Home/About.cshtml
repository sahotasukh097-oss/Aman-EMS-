@{
    ViewData["Title"] = "About SAPS - HR Management Software";
}

<!-- About Hero Section -->
<section class="about-hero">
    <div class="container-fluid">
        <h1>About SAPS</h1>
        <p>SAPS is a modern Human Resource Management (HRM) platform designed to help organizations manage their workforce efficiently.</p>
    </div>
</section>

<!-- Mission Section -->
<section class="mission-section">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="mission-card">
                    <h2>Our Mission</h2>
                    <p>To empower organizations with powerful, accessible HR management tools that drive productivity and employee satisfaction.</p>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="deployment-info">
                    <h2>Deployment Options</h2>
                    <ul>
                        <li><strong>AMAN Open-Source:</strong> Free, self-hosted edition for full control over your data and infrastructure.</li>
                        <li><strong>AMAN Cloud:</strong> Fully managed, enterprise-grade HRMS for scalability and ease of use.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Story Section -->
<section class="story-section">
    <div class="container-fluid">
        <h2>Our Story</h2>
        <p>Founded in 2020, AMAN started as a passion project to create accessible HR software for small and medium-sized businesses. What began as a simple employee management tool has grown into a comprehensive platform used by organizations worldwide.</p>
        <p>We believe in the power of open-source development and welcome contributions from developers worldwide. Our GitHub repository is actively maintained, and we encourage feature requests, bug reports, and code contributions.</p>
    </div>
</section>

<!-- Technology Stack Section -->
<section class="tech-stack-section">
    <div class="container-fluid">
        <h2>Technology Stack</h2>
        <div class="tech-grid">
            <div class="tech-card">
                <h4>Backend</h4>
                <p>PHP 7.4+ with MVC architecture</p>
            </div>
            <div class="tech-card">
                <h4>Database</h4>
                <p>MySQL/MariaDB with UTF8MB4 support</p>
            </div>
            <div class="tech-card">
                <h4>Frontend</h4>
                <p>Bootstrap-based responsive UI</p>
            </div>
            <div class="tech-card">
                <h4>Security</h4>
                <p>Role-based access control & encryption</p>
            </div>
        </div>
    </div>
</section>

<!-- Screenshots Section -->
<section class="screenshots-section">
    <div class="container-fluid">
        <h2>Application Screenshots</h2>
        <p class="screenshots-subtitle">See AMAN HR Management System in action with real interface screenshots.</p>
        
        <div class="screenshots-grid">
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-chart-line"></i>
                </div>
                <p>Dashboard Overview</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-user-plus"></i>
                </div>
                <p>Add New Employee</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <p>Apply for Leave</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-tasks"></i>
                </div>
                <p>Leave Management</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
                <p>Generate Payroll</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <p>Payroll Management</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-clock"></i>
                </div>
                <p>Mark Attendance</p>
            </div>
            <div class="screenshot-card">
                <div class="screenshot-placeholder">
                    <i class="fas fa-sign-in-alt"></i>
                </div>
                <p>Login Demo</p>
            </div>
        </div>

        <div class="screenshot-cta">
            <p>Experience the full AMAN HR system with 65+ employees, complete attendance records, leave management, and payroll processing.</p>
            <button class="btn btn-cta">View Demo</button>
        </div>
    </div>
</section>

<!-- Community Section -->
<section class="community-section">
    <div class="container-fluid">
        <h2>Community & Open Source</h2>
        <p>AMAN is proudly open source under the MIT license. We believe in the power of community-driven development and welcome contributions from developers worldwide. Our GitHub repository is actively maintained, and we encourage feature requests, bug reports, and code contributions.</p>
        <div class="community-links">
            <a href="#" class="community-link">
                <i class="fab fa-github"></i> GitHub Repository
            </a>
            <a href="#" class="community-link">
                <i class="fas fa-comments"></i> Community Forum
            </a>
            <a href="#" class="community-link">
                <i class="fas fa-book"></i> Documentation
            </a>
            <a href="#" class="community-link">
                <i class="fas fa-code-branch"></i> Contribute
            </a>
        </div>
    </div>
</section>
