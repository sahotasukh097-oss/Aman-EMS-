@{
    ViewData["Title"] = "Features - SAPS HR Management Software";
}

<!-- Features Hero Section -->
<section class="features-hero">
    <div class="container-fluid">
        <h1>Features</h1>
        <p>AMAN Open-Source Edition includes core HR modules to manage essential workforce operations:</p>
    </div>
</section>

<!-- Core Features Section -->
<section class="features-main">
    <div class="container-fluid">
        <div class="features-large-grid">
            <div class="feature-large-card">
                <div class="feature-icon">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Employee Management</h3>
                <p>Maintain comprehensive employee records, including personal details, job information, and organizational structure. Manage employee profiles, roles, departments, and hierarchies efficiently.</p>
            </div>
            <div class="feature-large-card">
                <div class="feature-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <h3>Attendance Tracking</h3>
                <p>Monitor employee attendance, track working hours, and generate comprehensive attendance reports. Automated attendance calculations and real-time tracking for better visibility.</p>
            </div>
            <div class="feature-large-card">
                <div class="feature-icon">
                    <i class="fas fa-calendar-times"></i>
                </div>
                <h3>Leave Management</h3>
                <p>Handle leave requests, approvals, and balance tracking for various leave types. Streamline the leave application process with automatic approval workflows and compliance tracking.</p>
            </div>
            <div class="feature-large-card">
                <div class="feature-icon">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
                <h3>Payroll Management</h3>
                <p>Process payroll calculations, manage salary structures, and generate payslips. Automated payroll processing with support for various salary components, deductions, and tax calculations.</p>
            </div>
        </div>
    </div>
</section>

<!-- Additional Features Section -->
<section class="additional-features">
    <div class="container-fluid">
        <h2 class="section-title">Additional Features</h2>
        <div class="features-grid">
            <div class="feature-card">
                <i class="fas fa-key"></i>
                <h4>Role-Based Access Control</h4>
                <p>Define custom roles and permissions to control user access at granular levels.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-file-pdf"></i>
                <h4>Report Generation</h4>
                <p>Generate comprehensive reports for attendance, payroll, and employee data.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-mobile-alt"></i>
                <h4>Responsive Interface</h4>
                <p>Access AMAN from any device with a fully responsive Bootstrap-based UI.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-lock"></i>
                <h4>Data Encryption</h4>
                <p>Secure sensitive employee data with industry-standard encryption protocols.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-chart-bar"></i>
                <h4>Analytics & Insights</h4>
                <p>Gain insights into workforce metrics and HR analytics with visual dashboards.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-code"></i>
                <h4>Customizable</h4>
                <p>Full access to source code allows complete customization for your organization's needs.</p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="benefits-section">
    <div class="container-fluid">
        <h2 class="section-title">Key Benefits</h2>
        <div class="benefits-grid">
            <div class="benefit-card">
                <div class="benefit-number">1</div>
                <h4>Cost Effective</h4>
                <p>Free, open-source solution eliminates licensing costs while maintaining enterprise-grade functionality.</p>
            </div>
            <div class="benefit-card">
                <div class="benefit-number">2</div>
                <h4>Full Control</h4>
                <p>Self-hosted deployment gives you complete control over your data and infrastructure.</p>
            </div>
            <div class="benefit-card">
                <div class="benefit-number">3</div>
                <h4>Flexible & Scalable</h4>
                <p>Easily customize and scale the system as your organization grows.</p>
            </div>
            <div class="benefit-card">
                <div class="benefit-number">4</div>
                <h4>Community Support</h4>
                <p>Active community of developers and users ready to help and contribute.</p>
            </div>
            <div class="benefit-card">
                <div class="benefit-number">5</div>
                <h4>Regular Updates</h4>
                <p>Continuous improvements and updates ensure the system stays current with latest standards.</p>
            </div>
            <div class="benefit-card">
                <div class="benefit-number">6</div>
                <h4>Easy Integration</h4>
                <p>Simple APIs and integrations with other business applications and services.</p>
            </div>
        </div>
    </div>
</section>

<!-- Comparison Section -->
<section class="comparison-section">
    <div class="container-fluid">
        <h2 class="section-title">AMAN vs Traditional HR Systems</h2>
        <div class="table-responsive">
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th>AMAN</th>
                        <th>Traditional Systems</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Cost</td>
                        <td><i class="fas fa-check text-success"></i> Free</td>
                        <td><i class="fas fa-times text-danger"></i> Expensive</td>
                    </tr>
                    <tr>
                        <td>Open Source</td>
                        <td><i class="fas fa-check text-success"></i> Yes</td>
                        <td><i class="fas fa-times text-danger"></i> Proprietary</td>
                    </tr>
                    <tr>
                        <td>Customizable</td>
                        <td><i class="fas fa-check text-success"></i> Fully</td>
                        <td><i class="fas fa-times text-danger"></i> Limited</td>
                    </tr>
                    <tr>
                        <td>Data Control</td>
                        <td><i class="fas fa-check text-success"></i> Full Control</td>
                        <td><i class="fas fa-times text-danger"></i> Cloud Dependent</td>
                    </tr>
                    <tr>
                        <td>Community Support</td>
                        <td><i class="fas fa-check text-success"></i> Active Community</td>
                        <td><i class="fas fa-times text-danger"></i> Paid Support Only</td>
                    </tr>
                    <tr>
                        <td>Implementation Speed</td>
                        <td><i class="fas fa-check text-success"></i> Fast</td>
                        <td><i class="fas fa-times text-danger"></i> Slow</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="features-cta">
    <div class="container-fluid">
        <h2>Ready to Experience AMAN?</h2>
        <p>Start managing your HR processes efficiently with AMAN today.</p>
        <div class="cta-buttons">
            <a href="/" class="btn btn-explore">Back to Home</a>
            <a href="#" class="btn btn-python">View Demo</a>
        </div>
    </div>
</section>
