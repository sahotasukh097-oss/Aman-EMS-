@{
    ViewData["Title"] = "Contact - SAPS HR Management Software";
}

<!-- Contact Hero Section -->
<section class="contact-hero">
    <div class="container-fluid">
        <h1>Contact Us</h1>
        <p>Get in touch with the AMAN team for support, inquiries, or contributions.</p>
    </div>
</section>

<!-- Contact Form Section -->
<section class="contact-form-section">
    <div class="container-fluid">
        <div class="contact-form-wrapper">
            <div class="contact-card">
                <h2>Send us a Message</h2>
                <form id="contactForm" class="contact-form">
                    <div class="form-group">
                        <label for="name">Full Name *</label>
                        <input type="text" id="name" name="name" required class="form-control">
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" required class="form-control">
                    </div>
                    <div class="form-group">
                        <label for="organization">Organization</label>
                        <input type="text" id="organization" name="organization" class="form-control">
                    </div>
                    <div class="form-group">
                        <label for="subject">Subject *</label>
                        <select id="subject" name="subject" required class="form-control">
                            <option value="">Select a subject</option>
                            <option value="support">Support</option>
                            <option value="feature">Feature Request</option>
                            <option value="bug">Bug Report</option>
                            <option value="partnership">Partnership</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Message *</label>
                        <textarea id="message" name="message" required rows="6" class="form-control"></textarea>
                    </div>
                    <button type="submit" class="btn btn-submit">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Contact Information Section -->
<section class="contact-info-section">
    <div class="container-fluid">
        <h2 class="section-title">Get in Touch</h2>
        <div class="contact-info-grid">
            <div class="contact-info-card">
                <div class="info-icon">
                    <i class="fas fa-envelope"></i>
                </div>
                <h3>Email</h3>
                <p><a href="mailto:contact@aman-hr.com">contact@aman-hr.com</a></p>
            </div>
            <div class="contact-info-card">
                <div class="info-icon">
                    <i class="fas fa-phone"></i>
                </div>
                <h3>Phone</h3>
                <p><a href="tel:+15551234567">+1 (555) 123-4567</a></p>
            </div>
            <div class="contact-info-card">
                <div class="info-icon">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <h3>Location</h3>
                <p>Available Online<br>Remote Support Worldwide</p>
            </div>
        </div>
    </div>
</section>

<!-- Support Options Section -->
<section class="support-options-section">
    <div class="container-fluid">
        <h2 class="section-title">Other Ways to Get Help</h2>
        <div class="support-grid">
            <div class="support-card">
                <div class="support-icon">
                    <i class="fab fa-github"></i>
                </div>
                <h3>GitHub Issues</h3>
                <p>Report bugs or request features on our GitHub repository.</p>
                <a href="https://github.com/aman-hrm" class="support-link">Visit GitHub</a>
            </div>
            <div class="support-card">
                <div class="support-icon">
                    <i class="fas fa-comments"></i>
                </div>
                <h3>Community Forum</h3>
                <p>Join our community forum to discuss with other users.</p>
                <a href="https://forum.aman-hr.com" class="support-link">Visit Forum</a>
            </div>
            <div class="support-card">
                <div class="support-icon">
                    <i class="fas fa-book"></i>
                </div>
                <h3>Documentation</h3>
                <p>Explore our comprehensive documentation and guides.</p>
                <a href="https://docs.aman-hr.com" class="support-link">Read Docs</a>
            </div>
            <div class="support-card">
                <div class="support-icon">
                    <i class="fas fa-play-circle"></i>
                </div>
                <h3>Demo Access</h3>
                <p>Try AMAN with our live demo and sample data.</p>
                <a href="#" class="support-link">View Demo</a>
            </div>
        </div>
    </div>
</section>

<!-- Social Links Section -->
<section class="social-section">
    <div class="container-fluid">
        <h2>Follow Us</h2>
        <p>Stay updated with the latest news and updates</p>
        <div class="social-links-contact">
            <a href="#" class="social-icon"><i class="fab fa-facebook"></i></a>
            <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
            <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
            <a href="#" class="social-icon"><i class="fab fa-linkedin"></i></a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            // Show success message
            alert('Thank you for your message! We will get back to you soon.');
            this.reset();
        });
    </script>
}
