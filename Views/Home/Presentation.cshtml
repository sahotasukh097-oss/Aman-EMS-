@{
    ViewData["Title"] = "SAPS EMS - Professional Presentation";
}

<link rel="stylesheet" href="~/css/presentation.css">

<!-- Hero Section -->
<section class="presentation-hero">
    <div class="hero-content">
        <div class="hero-text">
            <div class="hero-badge">
                <i class="fas fa-star"></i> Trusted by 500+ Organizations
            </div>
            <h1 class="hero-title">Transform Your HR Operations</h1>
            <p class="hero-subtitle">SAPS EMS - Enterprise Employee Management System</p>
            <p class="hero-description">Streamline workforce management with intelligent automation, real-time analytics, and seamless integration. Deploy smarter, manage faster, succeed bigger.</p>
            <div class="hero-buttons">
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg btn-glow">
                    <i class="fas fa-play"></i> Start Free Trial
                </a>
                <a href="@Url.Action("Features", "Home")" class="btn btn-outline btn-lg">
                    <i class="fas fa-arrow-right"></i> See Features
                </a>
            </div>
            <p class="hero-footer">No credit card required • 30-day free trial • Access to all features</p>
        </div>
        <div class="hero-visual">
            <div class="hero-decoration hero-decoration-1"></div>
            <div class="hero-decoration hero-decoration-2"></div>
            <div class="hero-decoration-text">
                <div class="feature-mini">
                    <i class="fas fa-check-circle"></i>
                    <span>Smart Automation</span>
                </div>
                <div class="feature-mini">
                    <i class="fas fa-bolt"></i>
                    <span>Real-Time Analytics</span>
                </div>
                <div class="feature-mini">
                    <i class="fas fa-shield-alt"></i>
                    <span>Enterprise Security</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section class="presentation-stats">
    <div class="container-fluid">
        <h2 class="section-title">Trusted by Industry Leaders</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">10,000+</div>
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Active Users</h3>
                <p>Managing employees worldwide</p>
            </div>
            <div class="stat-card">
                <div class="stat-number">500+</div>
                <div class="stat-icon">
                    <i class="fas fa-building"></i>
                </div>
                <h3>Organizations</h3>
                <p>Across diverse industries</p>
            </div>
            <div class="stat-card">
                <div class="stat-number">99.9%</div>
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h3>Uptime SLA</h3>
                <p>Enterprise-grade reliability</p>
            </div>
            <div class="stat-card">
                <div class="stat-number">24/7</div>
                <div class="stat-icon">
                    <i class="fas fa-headset"></i>
                </div>
                <h3>Support</h3>
                <p>Dedicated expert team</p>
            </div>
        </div>
    </div>
</section>

<!-- Features Highlight Section -->
<section class="presentation-features">
    <div class="container-fluid">
        <div class="section-header">
            <h2 class="section-title">Powerful Features Built for Growth</h2>
            <p class="section-subtitle">Everything you need to manage your workforce efficiently and effectively</p>
        </div>
        <div class="features-showcase">
            <div class="feature-block">
                <div class="feature-icon gradient-icon-1">
                    <i class="fas fa-id-badge"></i>
                </div>
                <h3>Employee Management</h3>
                <p>Comprehensive profiles, org hierarchy, and complete personnel tracking with custom fields</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="feature-block">
                <div class="feature-icon gradient-icon-2">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3>Attendance Tracking</h3>
                <p>Real-time monitoring, shift management, and automated reporting with mobile access</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="feature-block">
                <div class="feature-icon gradient-icon-3">
                    <i class="fas fa-coins"></i>
                </div>
                <h3>Payroll Management</h3>
                <p>Automated calculations, tax compliance, multi-currency support, and secure payments</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="feature-block">
                <div class="feature-icon gradient-icon-4">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <h3>Leave Management</h3>
                <p>Flexible leave policies, approval workflows, and intelligent calendar management</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="feature-block">
                <div class="feature-icon gradient-icon-5">
                    <i class="fas fa-chart-area"></i>
                </div>
                <h3>Analytics Dashboard</h3>
                <p>Real-time insights, performance metrics, custom reports, and data visualization</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="feature-block">
                <div class="feature-icon gradient-icon-6">
                    <i class="fas fa-lock"></i>
                </div>
                <h3>Security & Compliance</h3>
                <p>Enterprise security, data privacy, regulatory compliance, and audit trails</p>
                <a href="@Url.Action("Features", "Home")" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

