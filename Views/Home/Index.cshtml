@{
    ViewData["Title"] = "SAPS - HR Management Software";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container-fluid">
        <div class="hero-content">
            <h1>Welcome to SAPS</h1>
            <p class="hero-subtitle">Open Source HR Management Software for Modern Organizations</p>
            <div class="hero-buttons">
                <button class="btn btn-explore" onclick="document.getElementById('features').scrollIntoView({behavior: 'smooth'})">
                    Explore Features
                </button>
                <button class="btn btn-python">View Python Demo</button>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose AMAN Section -->
<section class="why-choose-section" id="features">
    <div class="container-fluid">
        <h2 class="section-title">Why Choose AMAN?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <i class="fas fa-code"></i>
                <h4>Free & Open Source</h4>
                <p>Self-hosted HR software with no licensing fees.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-users"></i>
                <h4>Comprehensive HR Modules</h4>
                <p>Manage employees, attendance, leaves, and payroll efficiently.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-shield-alt"></i>
                <h4>Secure & Scalable</h4>
                <p>Built with security in-mind, suitable for businesses of all sizes.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-clock"></i>
                <h4>Easy Demo Access</h4>
                <p>Test the system with demo credentials. admin@aman.com / try1436</p>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials-section">
    <div class="container-fluid">
        <h2 class="section-title">What Our Users Say</h2>
        <div class="testimonials-grid">
            <div class="testimonial-card">
                <p class="testimonial-text">"AMAN has transformed our HR processes. The open-source nature gives us complete control and the features are exactly what we need."</p>
                <p class="testimonial-author">Sarah Johnson, HR Manager at TechCorp</p>
            </div>
            <div class="testimonial-card">
                <p class="testimonial-text">"Easy to implement and use. The distributed tracking and payroll features work perfectly for our needs."</p>
                <p class="testimonial-author">Michael Chen, Operations Director at BiznoYTZ</p>
            </div>
            <div class="testimonial-card">
                <p class="testimonial-text">"Outstanding support from the AMAN team. The scalability and features are perfectly positioned with other tools."</p>
                <p class="testimonial-author">Emily Rodriguez, CEO at InnovateTech</p>
            </div>
        </div>
    </div>
</section>
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section class="stats-section">
    <div class="container-fluid">
        <h2 class="section-title">AMAN by Numbers</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <h3 class="stat-number">10,000+</h3>
                <p class="stat-label">Active Users</p>
            </div>
            <div class="stat-card">
                <h3 class="stat-number">500+</h3>
                <p class="stat-label">Organizations</p>
            </div>
            <div class="stat-card">
                <h3 class="stat-number">50+</h3>
                <p class="stat-label">Countries</p>
            </div>
            <div class="stat-card">
                <h3 class="stat-number">4.8/5</h3>
                <p class="stat-label">User Rating</p>
            </div>
        </div>
    </div>
</section>

<!-- Deployment Options Section -->
<!-- Deployment Options Section -->
<section class="deployment-section">
    <div class="container-fluid">
        <h2 class="section-title">Choose Your Deployment</h2>
        <div class="deployment-grid">
            <div class="deployment-card">
                <h3>Open-Source Edition</h3>
                <p class="price">Free</p>
                <ul class="features-list">
                    <li><i class="fas fa-check"></i> Self-hosted on your infrastructure</li>
                    <li><i class="fas fa-check"></i> Complete data control</li>
                    <li><i class="fas fa-check"></i> Customizable source code</li>
                    <li><i class="fas fa-check"></i> Community support</li>
                    <li><i class="fas fa-check"></i> All core HR features</li>
                </ul>
                <button class="btn btn-deploy">Run Local Demo</button>
            </div>
            <div class="deployment-card cloud-edition">
                <span class="badge-popular">Most Popular</span>
                <h3>Cloud Edition</h3>
                <p class="price">Starting at<br><strong>$29/month</strong></p>
                <ul class="features-list">
                    <li><i class="fas fa-check"></i> Fully managed hosting</li>
                    <li><i class="fas fa-check"></i> Automatic updates</li>
                    <li><i class="fas fa-check"></i> 24/7 support</li>
                    <li><i class="fas fa-check"></i> Advanced security</li>
                    <li><i class="fas fa-check"></i> Scalable infrastructure</li>
                </ul>
                <button class="btn btn-deploy btn-cloud">View Cloud Demo</button>
            </div>
        </div>
    </div>
</section>
