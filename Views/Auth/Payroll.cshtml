    background: rgba(30, 40, 60, 0.8);
    border: 1px solid rgba(74, 158, 255, 0.3);
    color: white;
    border-radius: 6px;
    font-size: 14px;
}

.form-group input:focus,
.form-group select:focus {
    outline: none;
    border-color: #4a9eff;
    box-shadow: 0 0 0 3px rgba(74, 158, 255, 0.1);
}

.btn-submit {
    width: 100%;
    background: linear-gradient(135deg, #4a9eff 0%, #0066cc 100%);
    color: white;
    border: none;
    padding: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(74, 158, 255, 0.4);
}

.detail-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

.btn-print,
.btn-download {
    flex: 1;
    padding: 12px;
    border: 1px solid rgba(74, 158, 255, 0.3);
    background: rgba(74, 158, 255, 0.1);
    color: #4a9eff;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.btn-print:hover,
.btn-download:hover {
    background: rgba(74, 158, 255, 0.2);
}

.payroll-details {
    background: rgba(30, 40, 60, 0.5);
    border: 1px solid rgba(74, 158, 255, 0.2);
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
}

.detail-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(74, 158, 255, 0.1);
}

.detail-row:last-child {
    border-bottom: none;
}

.detail-label {
    color: #9ca3af;
}

.detail-value {
    color: #ffffff;
    font-weight: 600;
}
</style>

<script>
let currentMonth = new Date().toLocaleString('default', { month: 'long' });
let currentYear = new Date().getFullYear().toString();

function generatePayroll() {
    document.getElementById("payrollModal").style.display = "block";
}

function closePayrollModal() {
    document.getElementById("payrollModal").style.display = "none";
}

function closeDetailsModal() {
    document.getElementById("detailsModal").style.display = "none";
}

function applyPayrollFilters() {
    const month = document.getElementById('monthFilter').value;
    const year = document.getElementById('yearFilter').value;
    
    if (month && year) {
        loadPayroll(month, year);
    }
}

function savePayroll(event) {
    event.preventDefault();
    alert("Payroll generation functionality to be implemented");
    closePayrollModal();
}

function printPayslip() {
    window.print();
}

function downloadPayslip() {
    alert("Download functionality to be implemented");
}

function loadPayroll(month = null, year = null) {
    const queryMonth = month || currentMonth;
    const queryYear = year || currentYear;
    
    fetch(`/api/payroll?month=${queryMonth}&year=${queryYear}`)
        .then(response => response.json())
        .then(data => {
            const tableBody = document.getElementById('payrollTableBody');
            tableBody.innerHTML = '';
            
            if (data.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="7" class="text-center text-muted">No payroll records found</td></tr>';
                resetPayrollStats();
                return;
            }
            
            let totalPayroll = 0;
            let totalAllowances = 0;
            let totalDeductions = 0;
            
            data.forEach(payroll => {
                const row = document.createElement('tr');
                totalPayroll += payroll.netSalary || 0;
                totalAllowances += payroll.allowances || 0;
                totalDeductions += payroll.deductions || 0;
                
                row.innerHTML = `
                    <td>${payroll.employeeName}</td>
                    <td>$${(payroll.basicSalary || 0).toLocaleString()}</td>
                    <td>$${(payroll.allowances || 0).toLocaleString()}</td>
                    <td>$${(payroll.deductions || 0).toLocaleString()}</td>
                    <td>$${(payroll.netSalary || 0).toLocaleString()}</td>
                    <td>${payroll.month} ${payroll.year}</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn-action btn-view" onclick="viewPayrollDetails(${payroll.id})"><i class="fas fa-eye"></i> View</button>
                            <button class="btn-action btn-print" onclick="printPayslip()"><i class="fas fa-print"></i> Print</button>
                        </div>
                    </td>
                `;
                tableBody.appendChild(row);
            });
            
            document.getElementById('totalPayroll').textContent = '$' + totalPayroll.toLocaleString();
            document.getElementById('totalAllowances').textContent = '$' + totalAllowances.toLocaleString();
            document.getElementById('totalDeductions').textContent = '$' + totalDeductions.toLocaleString();
            document.getElementById('employeesProcessed').textContent = data.length;
        })
        .catch(error => console.error('Error loading payroll:', error));
}

function resetPayrollStats() {
    document.getElementById('totalPayroll').textContent = '$0';
    document.getElementById('totalAllowances').textContent = '$0';
    document.getElementById('totalDeductions').textContent = '$0';
    document.getElementById('employeesProcessed').textContent = '0';
}

function viewPayrollDetails(payrollId) {
    document.getElementById("detailsModal").style.display = "block";
}

window.addEventListener('load', () => {
    loadPayroll();
});

// Close modal when clicking outside
window.onclick = function(event) {
    const payrollModal = document.getElementById("payrollModal");
    const detailsModal = document.getElementById("detailsModal");
    
    if (event.target == payrollModal) {
        payrollModal.style.display = "none";
    }
    if (event.target == detailsModal) {
        detailsModal.style.display = "none";
    }
}
</script>
