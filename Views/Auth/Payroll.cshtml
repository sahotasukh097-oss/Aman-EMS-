}

.filter-group {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 150px;
}

.filter-group label {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 5px;
    color: #d1d5db;
}

.form-control {
    background: rgba(30, 40, 60, 0.8);
    border: 1px solid rgba(74, 158, 255, 0.3);
    color: white;
    padding: 10px 12px;
    border-radius: 6px;
