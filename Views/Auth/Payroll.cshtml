}

.btn-print {
    background: rgba(99, 102, 241, 0.2);
    color: #6366f1;
}

.btn-print:hover {
    background: rgba(99, 102, 241, 0.4);
}

.text-center {
    text-align: center;
}

.text-muted {
    color: #9ca3af;
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    margin: 5% auto;
    padding: 30px;
    border: 1px solid rgba(74, 158, 255, 0.3);
    border-radius: 12px;
    width: 90%;
