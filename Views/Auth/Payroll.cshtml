    color: white;
    max-height: 80vh;
    overflow-y: auto;
}

.close {
    color: #9ca3af;
    float: right;
    font-size: 28px;
    font-weight: bold;
    cursor: pointer;
}

.close:hover {
    color: white;
}

.modal-content h2 {
    margin-top: 0;
