}

.navbar-right {
    display: flex;
    align-items: center;
    gap: 15px;
}

.nav-logout {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
