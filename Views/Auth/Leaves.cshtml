}

.btn-view:hover {
    background: rgba(74, 158, 255, 0.4);
}

.btn-delete {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
}

.btn-delete:hover {
    background: rgba(239, 68, 68, 0.4);
}

.text-center {
    text-align: center;
}

.text-muted {
    color: #9ca3af;
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    margin: 5% auto;
    padding: 30px;
    border: 1px solid rgba(74, 158, 255, 0.3);
    border-radius: 12px;
    width: 90%;
    max-width: 500px;
    color: white;
    max-height: 80vh;
    overflow-y: auto;
}

.close {
    color: #9ca3af;
    float: right;
    font-size: 28px;
    font-weight: bold;
    cursor: pointer;
}

.close:hover {
    color: white;
}

.modal-content h2 {
    margin-top: 0;
    color: #4a9eff;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #d1d5db;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 10px;
    background: rgba(30, 40, 60, 0.8);
    border: 1px solid rgba(74, 158, 255, 0.3);
    color: white;
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: #4a9eff;
    box-shadow: 0 0 0 3px rgba(74, 158, 255, 0.1);
}

.btn-submit {
    width: 100%;
    background: linear-gradient(135deg, #4a9eff 0%, #0066cc 100%);
    color: white;
    border: none;
    padding: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(74, 158, 255, 0.4);
}

.review-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

.btn-approve {
    flex: 1;
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
    border: 1px solid #10b981;
    padding: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.btn-approve:hover {
    background: rgba(16, 185, 129, 0.4);
}

.btn-reject {
    flex: 1;
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border: 1px solid #ef4444;
    padding: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
