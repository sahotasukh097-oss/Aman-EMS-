.btn-reject:hover {
    background: rgba(239, 68, 68, 0.4);
}
</style>

<script>
function applyForLeave() {
    document.getElementById("leaveModal").style.display = "block";
}

function closeLeaveModal() {
    document.getElementById("leaveModal").style.display = "none";
}

function closeReviewModal() {
    document.getElementById("reviewModal").style.display = "none";
}

function applyLeaveFilters() {
    loadLeaves();
}

function saveLeave(event) {
    event.preventDefault();
    alert("Save functionality to be implemented");
    closeLeaveModal();
}

function approveLeave() {
    alert("Leave approved successfully");
    closeReviewModal();
    loadLeaves();
}

function rejectLeave() {
    alert("Leave rejected successfully");
    closeReviewModal();
    loadLeaves();
}

function loadLeaves() {
    fetch('/api/leaves')
        .then(response => response.json())
        .then(data => {
            const tableBody = document.getElementById('leavesTableBody');
            tableBody.innerHTML = '';
            
            if (data.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No leave records found</td></tr>';
                return;
            }
            
            data.forEach(leave => {
                const row = document.createElement('tr');
                const startDate = new Date(leave.startDate).toLocaleDateString();
                const endDate = new Date(leave.endDate).toLocaleDateString();
                
                row.innerHTML = `
                    <td>${leave.employeeName}</td>
                    <td>${leave.leaveType}</td>
                    <td>${startDate}</td>
                    <td>${endDate}</td>
                    <td><span class="status-badge status-${leave.status}">${leave.status}</span></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn-action btn-view" onclick="reviewLeave(${leave.id})"><i class="fas fa-eye"></i> Review</button>
                        </div>
                    </td>
                `;
                tableBody.appendChild(row);
            });
        })
        .catch(error => console.error('Error loading leaves:', error));
}

function reviewLeave(leaveId) {
    document.getElementById("reviewModal").style.display = "block";
}

window.addEventListener('load', loadLeaves);

// Close modal when clicking outside
window.onclick = function(event) {
    const leaveModal = document.getElementById("leaveModal");
    const reviewModal = document.getElementById("reviewModal");
    
    if (event.target == leaveModal) {
        leaveModal.style.display = "none";
    }
    if (event.target == reviewModal) {
        reviewModal.style.display = "none";
    }
}
</script>
