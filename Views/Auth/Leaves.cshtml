@{
    ViewData["Title"] = "Leave Management - AMAN HR";
}

<!-- Navigation Bar -->
<nav class="dashboard-navbar">
    <div class="navbar-left">
        <a href="/Auth/Dashboard" class="navbar-logo">
            <i class="fas fa-circle-notch"></i> AMAN HR
        </a>
        <div class="navbar-links">
            <a href="/Auth/Dashboard" class="nav-link">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a href="/Auth/Employees" class="nav-link">
                <i class="fas fa-users"></i> Employees
            </a>
            <a href="/Auth/Attendance" class="nav-link">
                <i class="fas fa-calendar-check"></i> Attendance
            </a>
            <a href="/Auth/Leaves" class="nav-link active">
                <i class="fas fa-calendar-alt"></i> Leaves
            </a>
            <a href="/Auth/Payroll" class="nav-link">
                <i class="fas fa-money-bill"></i> Payroll
            </a>
        </div>
    </div>
    <div class="navbar-right">
        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="nav-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</nav>

<div class="leaves-page">
    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="header-text">
                <h1>Leave Management</h1>
                <p>Review leave requests and manage approvals across your team.</p>
            </div>
        </div>
        <button class="btn-primary" onclick="applyForLeave()">
            <i class="fas fa-plus"></i> Apply Leave
        </button>
    </div>

    <!-- Filter Section -->
    <div class="filters-section">
        <div class="filter-group">
            <label>Leave Type</label>
            <select id="leaveTypeFilter" class="form-control">
                <option value="">All Leave Types</option>
                <option value="sick">Sick Leave</option>
                <option value="casual">Casual Leave</option>
                <option value="unpaid">Unpaid Leave</option>
                <option value="maternity">Maternity Leave</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select id="statusFilter" class="form-control">
                <option value="">All Status</option>
                <option value="pending">Pending</option>
                <option value="approved">Approved</option>
                <option value="rejected">Rejected</option>
            </select>
        </div>
        <button class="btn-filter" onclick="applyLeaveFilters()">
            <i class="fas fa-search"></i> Filter
        </button>
    </div>

    <!-- Leaves Table -->
    <div class="table-wrapper">
        <table class="leaves-table">
            <thead>
                <tr>
                    <th><i class="fas fa-user"></i> Employee</th>
                    <th><i class="fas fa-leaf"></i> Leave Type</th>
                    <th><i class="fas fa-calendar"></i> Start Date</th>
                    <th><i class="fas fa-calendar"></i> End Date</th>
                    <th><i class="fas fa-toggle-on"></i> Status</th>
                    <th><i class="fas fa-cogs"></i> Actions</th>
                </tr>
            </thead>
            <tbody id="leavesTableBody">
                <tr>
                    <td colspan="6" class="text-center text-muted">Loading leave records...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Apply Leave Modal -->
<div id="leaveModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeLeaveModal()">&times;</span>
        <h2>Apply for Leave</h2>
        <form id="leaveForm" onsubmit="saveLeave(event)">
            <div class="form-group">
                <label for="leaveType">Leave Type</label>
                <select id="leaveType" required>
                    <option value="">Select Leave Type</option>
                    <option value="sick">Sick Leave</option>
                    <option value="casual">Casual Leave</option>
                    <option value="unpaid">Unpaid Leave</option>
                    <option value="maternity">Maternity Leave</option>
                </select>
            </div>
            <div class="form-group">
                <label for="startDate">Start Date</label>
                <input type="date" id="startDate" required>
            </div>
            <div class="form-group">
                <label for="endDate">End Date</label>
                <input type="date" id="endDate" required>
            </div>
            <div class="form-group">
                <label for="reason">Reason</label>
                <textarea id="reason" rows="4" placeholder="Enter reason for leave..."></textarea>
            </div>
            <button type="submit" class="btn-submit">Submit Leave Request</button>
        </form>
    </div>
</div>

<!-- Review Leave Modal -->
<div id="reviewModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeReviewModal()">&times;</span>
        <h2>Review Leave Request</h2>
        <div id="reviewContent"></div>
        <div class="review-actions">
            <button class="btn-approve" onclick="approveLeave()">
                <i class="fas fa-check"></i> Approve
            </button>
            <button class="btn-reject" onclick="rejectLeave()">
                <i class="fas fa-times"></i> Reject
            </button>
        </div>
    </div>
</div>

<style>
