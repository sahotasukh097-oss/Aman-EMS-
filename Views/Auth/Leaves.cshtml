.leaves-table td {
    padding: 15px;
    border-bottom: 1px solid rgba(74, 158, 255, 0.1);
}

.leaves-table tbody tr:hover {
    background: rgba(74, 158, 255, 0.1);
}

.status-badge {
    padding: 6px 12px;
    border-radius: 20px;
