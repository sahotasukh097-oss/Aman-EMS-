@{
    ViewData["Title"] = "Employee Management - AMAN HR";
}

<!-- Navigation Bar -->
<nav class="dashboard-navbar">
    <div class="navbar-left">
        <a href="/Auth/Dashboard" class="navbar-logo">
            <i class="fas fa-circle-notch"></i> AMAN HR
        </a>
        <div class="navbar-links">
            <a href="/Auth/Dashboard" class="nav-link">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a href="/Auth/Employees" class="nav-link active">
                <i class="fas fa-users"></i> Employees
            </a>
            <a href="/Auth/Attendance" class="nav-link">
                <i class="fas fa-calendar-check"></i> Attendance
            </a>
            <a href="/Auth/Leaves" class="nav-link">
                <i class="fas fa-calendar-alt"></i> Leaves
            </a>
            <a href="/Auth/Payroll" class="nav-link">
                <i class="fas fa-money-bill"></i> Payroll
            </a>
        </div>
    </div>
    <div class="navbar-right">
        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="nav-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</nav>

<div class="employees-page">
    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="header-text">
                <h1>Employee Management</h1>
                <p>View, search, and manage your employee records in one place.</p>
            </div>
        </div>
        <button class="btn-primary" onclick="openAddEmployeeModal()">
            <i class="fas fa-user-plus"></i> Add Employee
        </button>
    </div>

    <!-- Search & Filter Section -->
    <div class="search-filter-section">
        <h3><i class="fas fa-search"></i> Search & Filter Employees</h3>
        
        <div class="filter-grid">
            <div class="filter-group">
                <label>Search Name/Email</label>
                <input type="text" id="searchInput" placeholder="Search employees..." class="form-control">
            </div>
            
            <div class="filter-group">
                <label>Department</label>
                <select id="departmentFilter" class="form-control">
                    <option value="">All Departments</option>
                    <option value="HR">HR</option>
                    <option value="IT">IT</option>
                    <option value="Finance">Finance</option>
                    <option value="Operations">Operations</option>
                    <option value="Sales">Sales</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Status</label>
                <select id="statusFilter" class="form-control">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                    <option value="on-leave">On Leave</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Sort By</label>
                <select id="sortFilter" class="form-control">
                    <option value="name">Name</option>
                    <option value="department">Department</option>
                    <option value="salary">Salary</option>
                    <option value="date">Date Joined</option>
                </select>
            </div>
        </div>

        <div class="filter-actions">
            <button class="btn-search" onclick="applyFilters()"><i class="fas fa-search"></i> Search</button>
            <button class="btn-clear" onclick="clearFilters()"><i class="fas fa-times"></i> Clear</button>
            <button class="btn-export" onclick="exportEmployees()"><i class="fas fa-download"></i> Export CSV</button>
        </div>
    </div>

    <!-- Employee Count Info -->
    <div class="info-bar">
        <span id="employeeCount">Showing 0 employees</span>
    </div>

    <!-- Employees Table -->
    <div class="table-wrapper">
        <table class="employees-table">
            <thead>
                <tr>
                    <th><input type="checkbox" id="selectAll"></th>
                    <th><i class="fas fa-id-card"></i> ID</th>
                    <th><i class="fas fa-user"></i> Name</th>
                    <th><i class="fas fa-envelope"></i> Email</th>
                    <th><i class="fas fa-phone"></i> Phone</th>
                    <th><i class="fas fa-building"></i> Department</th>
                    <th><i class="fas fa-briefcase"></i> Position</th>
                    <th><i class="fas fa-dollar-sign"></i> Salary</th>
                    <th><i class="fas fa-toggle-on"></i> Status</th>
                    <th><i class="fas fa-cogs"></i> Actions</th>
                </tr>
            </thead>
            <tbody id="employeesTableBody">
                <tr>
                    <td colspan="10" class="text-center text-muted">Loading employees...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Employee Modal -->
<div id="employeeModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeEmployeeModal()">&times;</span>
        <h2>Add New Employee</h2>
        <form id="employeeForm" onsubmit="saveEmployee(event)">
            <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" required>
            </div>
            <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" required>
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" required>
            </div>
            <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone">
            </div>
            <div class="form-group">
                <label for="department">Department</label>
                <select id="department" required>
                    <option value="">Select Department</option>
                    <option value="HR">HR</option>
                    <option value="IT">IT</option>
                    <option value="Finance">Finance</option>
                    <option value="Operations">Operations</option>
                    <option value="Sales">Sales</option>
                </select>
            </div>
            <div class="form-group">
                <label for="designation">Position</label>
                <input type="text" id="designation" required>
            </div>
            <div class="form-group">
                <label for="salary">Salary</label>
                <input type="number" id="salary" required>
            </div>
            <div class="form-group">
                <label for="dateOfJoining">Date of Joining</label>
                <input type="date" id="dateOfJoining" required>
            </div>
            <button type="submit" class="btn-submit">Save Employee</button>
        </form>
    </div>
</div>

<style>
.dashboard-navbar {
    background: rgba(15, 23, 42, 0.95);
    border-bottom: 1px solid rgba(74, 158, 255, 0.2);
    padding: 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 900;
    backdrop-filter: blur(10px);
}

.navbar-left {
    display: flex;
    align-items: center;
    gap: 30px;
}

.navbar-logo {
    color: #4a9eff;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
}

.navbar-links {
    display: flex;
    gap: 0;
}

.nav-link {
    color: #9ca3af;
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    font-size: 14px;
}

.nav-link:hover {
    color: #4a9eff;
    background: rgba(74, 158, 255, 0.1);
}

.nav-link.active {
    color: #4a9eff;
    background: rgba(74, 158, 255, 0.2);
}

.navbar-right {
    display: flex;
    align-items: center;
    gap: 15px;
}

.nav-logout {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
}

.nav-logout:hover {
    background: rgba(239, 68, 68, 0.4);
    color: #ef4444;
}

.employees-page {
    padding: 20px;
    color: #ffffff;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.header-content {
    display: flex;
    align-items: center;
    gap: 20px;
}

.header-icon {
    font-size: 48px;
    color: #4a9eff;
}

.header-text h1 {
    font-size: 32px;
    margin: 0;
    font-weight: 600;
}

.header-text p {
    margin: 5px 0 0 0;
    color: #9ca3af;
}

.btn-primary {
    background: linear-gradient(135deg, #4a9eff 0%, #0066cc 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(74, 158, 255, 0.4);
}

.search-filter-section {
    background: rgba(20, 30, 50, 0.5);
    border: 1px solid rgba(74, 158, 255, 0.2);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
}

.search-filter-section h3 {
    margin-top: 0;
    color: #4a9eff;
    display: flex;
    align-items: center;
    gap: 10px;
}

.filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
    margin-bottom: 15px;
}

.filter-group {
    display: flex;
    flex-direction: column;
}

.filter-group label {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 5px;
    color: #d1d5db;
}

.form-control {
    background: rgba(30, 40, 60, 0.8);
    border: 1px solid rgba(74, 158, 255, 0.3);
    color: white;
    padding: 10px 12px;
    border-radius: 6px;
    font-size: 14px;
}

.form-control:focus {
    outline: none;
    border-color: #4a9eff;
    box-shadow: 0 0 0 3px rgba(74, 158, 255, 0.1);
}

.filter-actions {
    display: flex;
    gap: 10px;
}

.btn-search, .btn-clear, .btn-export {
    padding: 10px 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.3s ease;
}

.btn-search {
    background: #4a9eff;
    color: white;
}

.btn-search:hover {
    background: #0066cc;
}

.btn-clear {
    background: rgba(107, 114, 128, 0.5);
    color: white;
}

.btn-clear:hover {
    background: rgba(107, 114, 128, 0.8);
}

.btn-export {
    background: #10b981;
    color: white;
}

.btn-export:hover {
    background: #059669;
}

.info-bar {
    color: #9ca3af;
    font-size: 14px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.table-wrapper {
    overflow-x: auto;
    border: 1px solid rgba(74, 158, 255, 0.2);
    border-radius: 8px;
}

.employees-table {
    width: 100%;
    border-collapse: collapse;
    background: rgba(20, 30, 50, 0.5);
}

.employees-table thead {
    background: rgba(30, 40, 60, 0.8);
    border-bottom: 2px solid rgba(74, 158, 255, 0.3);
}

.employees-table th {
    padding: 15px;
    text-align: left;
    color: #9ca3af;
    font-weight: 600;
    font-size: 13px;
}

.employees-table td {
    padding: 15px;
    border-bottom: 1px solid rgba(74, 158, 255, 0.1);
}

.employees-table tbody tr:hover {
    background: rgba(74, 158, 255, 0.1);
}

.status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.status-active {
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
}

.status-inactive {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
}

.status-on-leave {
    background: rgba(251, 146, 60, 0.2);
    color: #fb923c;
}

.action-buttons {
    display: flex;
    gap: 8px;
}

.btn-action {
    padding: 6px 12px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.3s ease;
}

.btn-view {
    background: rgba(74, 158, 255, 0.2);
    color: #4a9eff;
}

.btn-view:hover {
    background: rgba(74, 158, 255, 0.4);
}

.btn-edit {
    background: rgba(251, 146, 60, 0.2);
    color: #fb923c;
}

.btn-edit:hover {
    background: rgba(251, 146, 60, 0.4);
}

.btn-delete {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
}

.btn-delete:hover {
    background: rgba(239, 68, 68, 0.4);
}

.text-center {
    text-align: center;
}

.text-muted {
    color: #9ca3af;
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    margin: 5% auto;
    padding: 30px;
    border: 1px solid rgba(74, 158, 255, 0.3);
    border-radius: 12px;
    width: 90%;
    max-width: 500px;
    color: white;
}

.close {
    color: #9ca3af;
    float: right;
    font-size: 28px;
    font-weight: bold;
    cursor: pointer;
}

.close:hover {
    color: white;
}

.modal-content h2 {
    margin-top: 0;
    color: #4a9eff;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #d1d5db;
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 10px;
    background: rgba(30, 40, 60, 0.8);
    border: 1px solid rgba(74, 158, 255, 0.3);
    color: white;
    border-radius: 6px;
    font-size: 14px;
}

.form-group input:focus,
.form-group select:focus {
    outline: none;
    border-color: #4a9eff;
    box-shadow: 0 0 0 3px rgba(74, 158, 255, 0.1);
}

.btn-submit {
    width: 100%;
    background: linear-gradient(135deg, #4a9eff 0%, #0066cc 100%);
    color: white;
    border: none;
    padding: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(74, 158, 255, 0.4);
}
</style>

<script>
function openAddEmployeeModal() {
    document.getElementById("employeeModal").style.display = "block";
}

function closeEmployeeModal() {
    document.getElementById("employeeModal").style.display = "none";
}

function applyFilters() {
    loadEmployees();
}

function clearFilters() {
    document.getElementById("searchInput").value = "";
    document.getElementById("departmentFilter").value = "";
    document.getElementById("statusFilter").value = "";
    loadEmployees();
}

function exportEmployees() {
    alert("Export functionality to be implemented");
}

function saveEmployee(event) {
    event.preventDefault();
    alert("Save functionality to be implemented");
    closeEmployeeModal();
}

function loadEmployees() {
    fetch('/api/employees')
        .then(response => response.json())
        .then(data => {
            const tableBody = document.getElementById('employeesTableBody');
            tableBody.innerHTML = '';
            
            if (data.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="10" class="text-center text-muted">No employees found</td></tr>';
                document.getElementById('employeeCount').textContent = 'Showing 0 employees';
                return;
            }
            
            data.forEach(employee => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><input type="checkbox"></td>
                    <td>${employee.id}</td>
                    <td>${employee.name}</td>
                    <td>${employee.email}</td>
                    <td>${employee.phone || 'N/A'}</td>
                    <td>${employee.department}</td>
                    <td>${employee.designation}</td>
                    <td>$${employee.salary?.toLocaleString() || '0'}</td>
                    <td><span class="status-badge status-${employee.status}">${employee.status}</span></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn-action btn-view"><i class="fas fa-eye"></i> View</button>
                            <button class="btn-action btn-edit"><i class="fas fa-edit"></i> Edit</button>
                            <button class="btn-action btn-delete"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </td>
                `;
                tableBody.appendChild(row);
            });
            
            document.getElementById('employeeCount').textContent = `Showing ${data.length} employees`;
        })
        .catch(error => console.error('Error loading employees:', error));
}

window.addEventListener('load', loadEmployees);
</script>
